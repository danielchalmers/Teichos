{
  "name": "teichos",
  "version": "0.0.0",
  "description": "A web extension to block URLs based on configurable regex filters with time-based scheduling",
  "type": "module",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "vite",
    "build:dev": "vite build --mode development",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "playwright:install": "playwright install --with-deps chromium",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "check:fast": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:test && npm run test:unit",
    "check": "npm run check:fast && npm run build && npm run test:e2e",
    "clean": "rimraf dist",
    "package": "npm run build && cd dist && zip -r ../teichos.zip ."
  },
  "keywords": [
    "webextension",
    "browser-extension",
    "url-blocker",
    "chrome-extension",
    "edge-extension"
  ],
  "author": "Daniel Chalmers",
  "license": "MIT",
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "rollup": "2.80.0"
  }
}
