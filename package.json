{
  "name": "teichos",
  "version": "0.0.0",
  "description": "A web extension to block URLs based on configurable regex filters with time-based scheduling",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "zip": "wxt zip",
    "postinstall": "wxt prepare",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "check:fast": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:test && npm run test",
    "check": "npm run check:fast && npm run test:e2e"
  },
  "keywords": [
    "webextension",
    "browser-extension",
    "url-blocker",
    "chrome-extension",
    "edge-extension"
  ],
  "author": "Daniel Chalmers",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.6.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5",
    "wxt": "^0.20.26"
  },
  "overrides": {
    "tmp": "^0.2.7",
    "uuid": "^11.1.1"
  }
}
