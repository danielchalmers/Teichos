{
  "name": "teichos",
  "version": "0.0.0",
  "description": "A web extension to block URLs based on configurable regex filters with time-based scheduling",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "plasmo dev --target=chrome-mv3 --src-path=src",
    "build:dev": "plasmo build --target=chrome-mv3 --tag=dev --src-path=src",
    "build": "plasmo build --target=chrome-mv3 --src-path=src",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "playwright:install": "playwright install --with-deps chromium",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "check:fast": "npm run format:check && npm run lint && npm run typecheck && npm run typecheck:test && npm run test:unit",
    "check": "npm run check:fast && npm run build && npm run test:e2e",
    "clean": "rimraf build .plasmo",
    "package": "npm run clean && plasmo package --target=chrome-mv3 --src-path=src"
  },
  "keywords": [
    "webextension",
    "browser-extension",
    "url-blocker",
    "chrome-extension",
    "edge-extension"
  ],
  "author": "Daniel Chalmers",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "plasmo": "^0.90.5",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "manifest": {
    "name": "Teichos: Page Blocker",
    "version": "0.0.0",
    "description": "Block URLs based on configurable regex filters with time-based scheduling",
    "permissions": [
      "alarms",
      "storage",
      "tabs",
      "webNavigation"
    ],
    "host_permissions": [
      "<all_urls>"
    ],
    "action": {
      "default_popup": "popup.html",
      "default_title": "Teichos: Page Blocker"
    },
    "options_ui": {
      "open_in_tab": true
    }
  },
  "alias": {
    "react": "./node_modules/react/index.js",
    "react/jsx-runtime": "./node_modules/react/jsx-runtime.js",
    "react-dom/client": "./node_modules/react-dom/client.js",
    "react-dom": "./node_modules/react-dom/index.js",
    "scheduler": "./node_modules/scheduler/index.js",
    "scheduler/tracing": "./node_modules/scheduler/tracing.js"
  }
}
