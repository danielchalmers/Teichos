{
  "name": "teichos",
  "version": "1.0.0",
  "description": "A web extension to block URLs based on configurable regex filters with time-based scheduling",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "tsx scripts/build.ts --watch --dev",
    "build:dev": "tsx scripts/build.ts --dev",
    "build": "tsx scripts/build.ts",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "playwright:install": "playwright install --with-deps chromium",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "verify": "tsx scripts/verify.ts",
    "clean": "rimraf dist",
    "package:dist": "tsx scripts/package.ts",
    "package": "npm run clean && npm run build && npm run package:dist",
    "apply-release-version": "tsx scripts/applyReleaseVersion.ts"
  },
  "keywords": [
    "webextension",
    "browser-extension",
    "url-blocker",
    "chrome-extension",
    "edge-extension"
  ],
  "author": "Daniel Chalmers",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/chrome": "^0.1.40",
    "@types/node": "^24.12.2",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
