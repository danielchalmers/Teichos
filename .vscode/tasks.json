{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ensure Dependencies",
      "type": "shell",
      "command": "if (Test-Path .\\node_modules\\.bin\\wxt.cmd) { Write-Host 'Dependencies already installed.' } else { npm ci }",
      "problemMatcher": []
    },
    {
      "label": "Build",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Dev",
      "type": "npm",
      "script": "build:dev",
      "problemMatcher": []
    },
    {
      "label": "Watch",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Test",
      "type": "npm",
      "script": "test",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Test E2E",
      "type": "npm",
      "script": "test:e2e",
      "group": "test"
    },
    {
      "label": "Lint",
      "type": "npm",
      "script": "lint"
    },
    {
      "label": "Type Check",
      "type": "npm",
      "script": "typecheck"
    }
  ]
}
