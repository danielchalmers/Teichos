{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Stop Chrome Debug Profile",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\stop-chrome-debug-profile.ps1",
        "-ProfilePath",
        "${workspaceFolder}\\.vscode\\chrome-debug-profile"
      ],
      "problemMatcher": []
    },
    {
      "label": "Ensure Dependencies",
      "type": "shell",
      "command": "if (Test-Path .\\node_modules\\.bin\\vite.cmd) { Write-Host 'Dependencies already installed.' } else { npm ci }",
      "problemMatcher": []
    },
    {
      "label": "Build",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Dev",
      "type": "npm",
      "script": "build:dev",
      "problemMatcher": []
    },
    {
      "label": "Install Playwright Chromium",
      "type": "npm",
      "script": "playwright:install",
      "problemMatcher": []
    },
    {
      "label": "Start Chrome Debug Profile",
      "type": "process",
      "command": "node",
      "args": [
        "${workspaceFolder}\\scripts\\launch-chrome-debug-profile.mjs",
        "--chrome",
        "${env:LOCALAPPDATA}\\ms-playwright\\chromium-1217\\chrome-win64\\chrome.exe",
        "--profile",
        "${workspaceFolder}\\.vscode\\chrome-debug-profile",
        "--extension",
        "${workspaceFolder}\\dist",
        "--port",
        "9333"
      ],
      "problemMatcher": []
    },
    {
      "label": "Build Dev and Ensure Playwright Chromium",
      "dependsOrder": "sequence",
      "dependsOn": ["Ensure Dependencies", "Build Dev", "Install Playwright Chromium"],
      "problemMatcher": []
    },
    {
      "label": "Launch Chrome Debug Profile",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Stop Chrome Debug Profile",
        "Ensure Dependencies",
        "Build Dev",
        "Install Playwright Chromium",
        "Start Chrome Debug Profile"
      ],
      "problemMatcher": []
    },
    {
      "label": "Watch",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in .*ms"
        }
      }
    },
    {
      "label": "Test",
      "type": "npm",
      "script": "test",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Test E2E",
      "type": "npm",
      "script": "test:e2e",
      "group": "test"
    },
    {
      "label": "Lint",
      "type": "npm",
      "script": "lint"
    },
    {
      "label": "Type Check",
      "type": "npm",
      "script": "typecheck"
    }
  ]
}
