{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ensure Dependencies",
      "type": "shell",
      "command": "if (Test-Path .\\node_modules\\.bin\\vite.cmd) { Write-Host 'Dependencies already installed.' } else { npm ci }",
      "problemMatcher": []
    },
    {
      "label": "Build",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build Dev",
      "type": "npm",
      "script": "build:dev",
      "problemMatcher": []
    },
    {
      "label": "Install Playwright Chromium",
      "type": "npm",
      "script": "playwright:install",
      "problemMatcher": []
    },
    {
      "label": "Build Dev and Ensure Playwright Chromium",
      "dependsOrder": "sequence",
      "dependsOn": ["Ensure Dependencies", "Build Dev", "Install Playwright Chromium"],
      "problemMatcher": []
    },
    {
      "label": "Watch",
      "type": "npm",
      "script": "dev",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "ready in .*ms"
        }
      }
    },
    {
      "label": "Test",
      "type": "npm",
      "script": "test",
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Test E2E",
      "type": "npm",
      "script": "test:e2e",
      "group": "test"
    },
    {
      "label": "Lint",
      "type": "npm",
      "script": "lint"
    },
    {
      "label": "Type Check",
      "type": "npm",
      "script": "typecheck"
    }
  ]
}
