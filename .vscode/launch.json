{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Playwright Chromium Extension",
      "type": "chrome",
      "request": "attach",
      "preLaunchTask": "Launch Chrome Debug Profile",
      "postDebugTask": "Stop Chrome Debug Profile",
      "address": "127.0.0.1",
      "port": 9333,
      "urlFilter": "about:blank",
      "timeout": 30000,
      "webRoot": "${workspaceFolder}/dist",
      "sourceMaps": false,
      "pauseForSourceMap": false
    }
  ]
}
