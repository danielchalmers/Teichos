{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Chrome for Testing Extension",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "Build Dev and Install Chrome for Testing",
      "runtimeExecutable": "${workspaceFolder}\\.cache\\chrome-for-testing\\chrome\\win64-148.0.7778.96\\chrome-win64\\chrome.exe",
      "url": "chrome://newtab/",
      "userDataDir": true,
      "runtimeArgs": [
        "--load-extension=${workspaceFolder}/dist",
        "--disable-extensions-except=${workspaceFolder}/dist",
        "--disable-features=DisableLoadExtensionCommandLineSwitch",
        "--enable-unsafe-extension-debugging",
        "--no-first-run",
        "--no-default-browser-check"
      ],
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true
    }
  ]
}
